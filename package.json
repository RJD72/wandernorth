      "app/services/savedTripsService.js",
      "app/store/useSavedTripsStore.js",
      "app/store/useEntitlementStore.js",
      "app/services/routeService.js",
      "app/services/googleRoutes.js",
      "app/services/poiSearchService.js",
      "app/services/poiService.js",
      "app/services/poiProviders/googlePoiProvider.js",
      "app/services/poiProviders/tomtomPoiProvider.js",
      "app/services/locationService.js",
      "app/services/googlePlaces.js",
      "app/services/placeSearchService.js"
